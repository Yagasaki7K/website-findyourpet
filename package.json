{
	"private": true,
	"scripts": {
		"dev": "next dev --turbo",
		"vercel": "next build",
		"start": "next start",
		"commit": "git pull && bun update && bun run vercel && read -p 'Descriptions Commit: ' message && git add . && echo -n \"$message - \" && node getTime.js | xargs -I {} git commit -m \"$message - {}\" && git push",
		"clean": "rm -rf node_modules && bun install"
	},
	"dependencies": {
		"dotenv": "^17.4.2",
		"firebase": "^12.16.0",
		"next": "^16.2.11",
		"next-seo": "^7.2.0",
		"react": "^19.2.8",
		"react-dom": "^19.2.8",
		"react-map-gl": "^8.1.1",
		"sonner": "^2.0.7",
		"styled-components": "^6.4.4"
	},
	"devDependencies": {
		"eslint": "^9.39.5",
		"eslint-config-next": "^16.2.11"
	}
}
